    end

    subgraph LNX["Linux frontend"]
        D1["disfwk_fe open"] --> D2["Connector / CRTC / Plane selection"] --> D3["Framebuffer registration"] --> D4["Atomic commit"] --> D5["RPMsg / RVGC flush request"]
