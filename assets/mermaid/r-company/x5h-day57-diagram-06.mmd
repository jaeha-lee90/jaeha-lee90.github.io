flowchart LR
    SRC["Camera frame / processed image / UI buffer"] --> FB["RTOS or Linux framebuffer"] --> KMS["disfwk_fe DRM / native display path"] --> P1["Plane selection"] --> P2["CRTC binding"] --> P3["Connector target"] --> OUT["Display HW scanout"] --> LCD["Main / passenger display"]

    HWC["Android HWC3"] --> SF["SurfaceFlinger"] --> P1
    CFG1["display_layout_configuration.xml"] --> HWC
    CFG2["display_settings.xml"] --> HWC
    CFG3["CarServiceOverlayXenVm"] --> SF

    classDef main fill:#EAF2FF,stroke:#2563EB,stroke-width:2px,color:#0F172A;
    classDef and fill:#F3E8FF,stroke:#9333EA,stroke-width:2px,color:#111827;
    classDef cfg fill:#F8FAFC,stroke:#94A3B8,stroke-width:1.5px,color:#334155;
    class SRC,FB,KMS,P1,P2,P3,OUT,LCD main;
    class HWC,SF and;
    class CFG1,CFG2,CFG3 cfg;
    linkStyle 0,1,2,3,4,5,6 stroke:#2563EB,stroke-width:3px;
    linkStyle 7,8 stroke:#9333EA,stroke-width:3px;
    linkStyle 9,10,11 stroke:#64748B,stroke-width:2px,stroke-dasharray: 5 4;
